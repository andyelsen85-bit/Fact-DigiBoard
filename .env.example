# ────────────────────────────────────────────────────────────
# DigiBoard — variables d'environnement
# Copier ce fichier en ".env" et adapter les valeurs
# ────────────────────────────────────────────────────────────

# Mot de passe PostgreSQL (partagé entre le container postgres et l'app)
POSTGRES_PASSWORD=changez_ce_mot_de_passe

# Clé secrète pour les sessions / tokens Bearer — OBLIGATOIRE en production
# Générer avec : openssl rand -hex 64
SESSION_SECRET=changez_cette_cle_secrete_longue_et_aleatoire

# Port exposé sur la machine hôte (défaut : 80)
APP_PORT=80
